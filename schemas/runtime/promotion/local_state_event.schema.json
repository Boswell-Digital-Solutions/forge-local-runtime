{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "runtime.local_state_event.v1",
  "title": "runtime.local_state_event.v1",
  "description": "Bounded local runtime state transition artifact eligible for governed fleet-learning promotion.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "envelope_type",
    "envelope_version",
    "producer_version",
    "runtime_bundle_id",
    "runtime_bundle_version",
    "fleet_member_id",
    "service",
    "capability",
    "prior_state",
    "new_state",
    "reason_class",
    "severity",
    "observed_at",
    "promotion_basis",
    "dedupe_key",
    "retention_class"
  ],
  "properties": {
    "envelope_type": {
      "const": "local_state_event"
    },
    "envelope_version": {
      "const": "v1"
    },
    "producer_version": {
      "type": "string",
      "minLength": 1
    },
    "runtime_bundle_id": {
      "type": "string",
      "minLength": 1
    },
    "runtime_bundle_version": {
      "type": "string",
      "minLength": 1
    },
    "fleet_member_id": {
      "type": "string",
      "minLength": 1
    },
    "service": {
      "type": "string",
      "enum": [
        "df_local_foundation",
        "neuronforge_local",
        "cortex",
        "fa_local"
      ]
    },
    "capability": {
      "type": "string",
      "minLength": 1
    },
    "prior_state": {
      "type": "string",
      "enum": [
        "ready",
        "degraded",
        "unavailable",
        "denied",
        "stale",
        "partial_success"
      ]
    },
    "new_state": {
      "type": "string",
      "enum": [
        "ready",
        "degraded",
        "unavailable",
        "denied",
        "stale",
        "partial_success"
      ]
    },
    "reason_class": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "pattern": "^[a-z0-9_./-]+$"
    },
    "severity": {
      "type": "string",
      "enum": [
        "low",
        "moderate",
        "high",
        "critical"
      ]
    },
    "observed_at": {
      "type": "string",
      "format": "date-time"
    },
    "promotion_basis": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "dedupe_key": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "retention_class": {
      "type": "string",
      "enum": ["A", "B", "C", "D", "E"]
    },
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "service_id": {
      "type": "string",
      "minLength": 1
    },
    "service_version": {
      "type": "string",
      "minLength": 1
    },
    "app_id": {
      "type": "string",
      "minLength": 1
    },
    "app_version": {
      "type": "string",
      "minLength": 1
    },
    "app_mode": {
      "type": "string",
      "enum": ["local", "hybrid", "cloud-enabled"]
    },
    "environment_class": {
      "type": "string",
      "enum": ["dev", "internal", "canary", "public"]
    },
    "platform_class": {
      "type": "string",
      "minLength": 1
    },
    "os_family": {
      "type": "string",
      "minLength": 1
    },
    "hardware_class": {
      "type": "string",
      "minLength": 1
    },
    "correlation_window": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "first_observed_at": {
      "type": "string",
      "format": "date-time"
    },
    "last_observed_at": {
      "type": "string",
      "format": "date-time"
    },
    "occurrence_count": {
      "type": "integer",
      "minimum": 1
    },
    "notes": {
      "type": "string",
      "maxLength": 500
    }
  }
}