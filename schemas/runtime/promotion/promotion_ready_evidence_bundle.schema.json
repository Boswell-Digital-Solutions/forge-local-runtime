{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "runtime.promotion_ready_evidence_bundle.v1",
  "title": "runtime.promotion_ready_evidence_bundle.v1",
  "description": "Bounded supporting evidence package eligible for governed fleet-learning promotion.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "envelope_type",
    "envelope_version",
    "producer_version",
    "runtime_bundle_id",
    "runtime_bundle_version",
    "fleet_member_id",
    "service",
    "issue_class",
    "artifact_refs",
    "redaction_class",
    "promotion_reason",
    "observed_at",
    "dedupe_key",
    "retention_class"
  ],
  "properties": {
    "envelope_type": {
      "const": "promotion_ready_evidence_bundle"
    },
    "envelope_version": {
      "const": "v1"
    },
    "producer_version": {
      "type": "string",
      "minLength": 1
    },
    "runtime_bundle_id": {
      "type": "string",
      "minLength": 1
    },
    "runtime_bundle_version": {
      "type": "string",
      "minLength": 1
    },
    "fleet_member_id": {
      "type": "string",
      "minLength": 1
    },
    "service": {
      "type": "string",
      "enum": [
        "df_local_foundation",
        "neuronforge_local",
        "cortex",
        "fa_local"
      ]
    },
    "issue_class": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[a-z0-9_./-]+$"
    },
    "artifact_refs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 25,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "artifact_id",
          "artifact_type"
        ],
        "properties": {
          "artifact_id": {
            "type": "string",
            "minLength": 1
          },
          "artifact_type": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120,
            "pattern": "^[a-z0-9_./-]+$"
          },
          "summary": {
            "type": "string",
            "maxLength": 240
          },
          "captured_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "redaction_class": {
      "type": "string",
      "enum": [
        "none",
        "runtime_metadata_only",
        "structured_summary_only",
        "strict_no_content"
      ]
    },
    "promotion_reason": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "observed_at": {
      "type": "string",
      "format": "date-time"
    },
    "dedupe_key": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "retention_class": {
      "type": "string",
      "enum": ["A", "B", "C", "D", "E"]
    },
    "evidence_bundle_id": {
      "type": "string",
      "minLength": 1
    },
    "service_id": {
      "type": "string",
      "minLength": 1
    },
    "service_version": {
      "type": "string",
      "minLength": 1
    },
    "app_id": {
      "type": "string",
      "minLength": 1
    },
    "app_version": {
      "type": "string",
      "minLength": 1
    },
    "app_mode": {
      "type": "string",
      "enum": ["local", "hybrid", "cloud-enabled"]
    },
    "environment_class": {
      "type": "string",
      "enum": ["dev", "internal", "canary", "public"]
    },
    "platform_class": {
      "type": "string",
      "minLength": 1
    },
    "os_family": {
      "type": "string",
      "minLength": 1
    },
    "hardware_class": {
      "type": "string",
      "minLength": 1
    },
    "promotion_basis": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "notes": {
      "type": "string",
      "maxLength": 500
    }
  }
}