{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "runtime.local_improvement_eval_result.v1",
  "title": "runtime.local_improvement_eval_result.v1",
  "description": "Bounded local runtime evaluation result for a candidate improvement eligible for governed fleet-learning promotion.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "envelope_type",
    "envelope_version",
    "producer_version",
    "runtime_bundle_id",
    "runtime_bundle_version",
    "fleet_member_id",
    "service",
    "candidate_id",
    "baseline_id",
    "evaluation_scope",
    "contract_checks",
    "runtime_truth_checks",
    "degraded_state_delta",
    "latency_delta",
    "cost_delta",
    "verification_summary",
    "observed_at",
    "dedupe_key",
    "retention_class"
  ],
  "properties": {
    "envelope_type": {
      "const": "local_improvement_eval_result"
    },
    "envelope_version": {
      "const": "v1"
    },
    "producer_version": {
      "type": "string",
      "minLength": 1
    },
    "runtime_bundle_id": {
      "type": "string",
      "minLength": 1
    },
    "runtime_bundle_version": {
      "type": "string",
      "minLength": 1
    },
    "fleet_member_id": {
      "type": "string",
      "minLength": 1
    },
    "service": {
      "type": "string",
      "enum": [
        "df_local_foundation",
        "neuronforge_local",
        "cortex",
        "fa_local"
      ]
    },
    "candidate_id": {
      "type": "string",
      "minLength": 1
    },
    "baseline_id": {
      "type": "string",
      "minLength": 1
    },
    "evaluation_scope": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "contract_checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "check_name",
          "status"
        ],
        "properties": {
          "check_name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 160
          },
          "status": {
            "type": "string",
            "enum": [
              "pass",
              "fail",
              "warning",
              "not_applicable"
            ]
          },
          "summary": {
            "type": "string",
            "maxLength": 240
          }
        }
      }
    },
    "runtime_truth_checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "check_name",
          "status"
        ],
        "properties": {
          "check_name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 160
          },
          "status": {
            "type": "string",
            "enum": [
              "pass",
              "fail",
              "warning",
              "not_applicable"
            ]
          },
          "summary": {
            "type": "string",
            "maxLength": 240
          }
        }
      }
    },
    "degraded_state_delta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "direction",
        "summary"
      ],
      "properties": {
        "direction": {
          "type": "string",
          "enum": [
            "improved",
            "worsened",
            "unchanged",
            "mixed"
          ]
        },
        "summary": {
          "type": "string",
          "maxLength": 240
        },
        "magnitude": {
          "type": "number"
        }
      }
    },
    "latency_delta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "direction",
        "summary"
      ],
      "properties": {
        "direction": {
          "type": "string",
          "enum": [
            "improved",
            "worsened",
            "unchanged",
            "mixed"
          ]
        },
        "summary": {
          "type": "string",
          "maxLength": 240
        },
        "magnitude": {
          "type": "number"
        }
      }
    },
    "cost_delta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "direction",
        "summary"
      ],
      "properties": {
        "direction": {
          "type": "string",
          "enum": [
            "improved",
            "worsened",
            "unchanged",
            "mixed"
          ]
        },
        "summary": {
          "type": "string",
          "maxLength": 240
        },
        "magnitude": {
          "type": "number"
        }
      }
    },
    "verification_summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "observed_at": {
      "type": "string",
      "format": "date-time"
    },
    "dedupe_key": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "retention_class": {
      "type": "string",
      "enum": ["A", "B", "C", "D", "E"]
    },
    "eval_result_id": {
      "type": "string",
      "minLength": 1
    },
    "service_id": {
      "type": "string",
      "minLength": 1
    },
    "service_version": {
      "type": "string",
      "minLength": 1
    },
    "app_id": {
      "type": "string",
      "minLength": 1
    },
    "app_version": {
      "type": "string",
      "minLength": 1
    },
    "app_mode": {
      "type": "string",
      "enum": ["local", "hybrid", "cloud-enabled"]
    },
    "environment_class": {
      "type": "string",
      "enum": ["dev", "internal", "canary", "public"]
    },
    "platform_class": {
      "type": "string",
      "minLength": 1
    },
    "os_family": {
      "type": "string",
      "minLength": 1
    },
    "hardware_class": {
      "type": "string",
      "minLength": 1
    },
    "promotion_basis": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "notes": {
      "type": "string",
      "maxLength": 500
    }
  }
}