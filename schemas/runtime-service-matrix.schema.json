{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://boswelldigitalsolutions.com/schemas/forge-local-runtime/runtime-service-matrix.schema.json",
  "title": "Forge Local Runtime Service Matrix",
  "description": "Aggregated snapshot composing the per-service status of all four local runtime services into one bounded view. A service that does not report is represented explicitly as unavailable / not_ready, never omitted (fail-closed).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "matrix_version",
    "generated_at",
    "services"
  ],
  "properties": {
    "matrix_version": {
      "const": "v1"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "correlation_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "details_redacted": {
      "type": "boolean",
      "default": true
    },
    "services": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "allOf": [
        {
          "contains": {
            "properties": { "service_id": { "const": "df-local-foundation" } },
            "required": ["service_id"]
          }
        },
        {
          "contains": {
            "properties": { "service_id": { "const": "neuronforge-local" } },
            "required": ["service_id"]
          }
        },
        {
          "contains": {
            "properties": { "service_id": { "const": "cortex" } },
            "required": ["service_id"]
          }
        },
        {
          "contains": {
            "properties": { "service_id": { "const": "fa-local" } },
            "required": ["service_id"]
          }
        }
      ],
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "service_id",
          "service_class",
          "state",
          "readiness_class",
          "observation",
          "last_updated_at"
        ],
        "properties": {
          "service_id": {
            "type": "string",
            "enum": [
              "df-local-foundation",
              "neuronforge-local",
              "cortex",
              "fa-local"
            ]
          },
          "service_class": {
            "type": "string",
            "enum": [
              "substrate",
              "inference",
              "file_intelligence",
              "execution"
            ]
          },
          "state": {
            "type": "string",
            "enum": [
              "ready",
              "degraded",
              "denied",
              "unavailable",
              "stale",
              "partial_success",
              "review_required",
              "waiting_explicit_approval"
            ]
          },
          "degraded_subtype": {
            "type": "string",
            "enum": [
              "degraded",
              "stale",
              "partial_success",
              "unavailable_dependency_block",
              "degraded_pre_start",
              "degraded_in_flight",
              "degraded_fallback_equivalent",
              "degraded_fallback_limited",
              "degraded_partial",
              "migration_blocked",
              "restore_constrained",
              "integrity_warning",
              "integrity_failed",
              "extraction_incomplete",
              "re_prep_required",
              "admitted_not_started",
              "waiting_explicit_approval",
              "completed_with_constraints"
            ]
          },
          "readiness_class": {
            "type": "string",
            "enum": [
              "ready",
              "ready_with_constraints",
              "degraded",
              "not_ready"
            ]
          },
          "blocking_reasons": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "dependency_unavailable",
                "migration_blocked",
                "integrity_failed",
                "policy_missing",
                "approval_required",
                "capacity_limited",
                "stale_artifacts",
                "route_unavailable"
              ]
            },
            "uniqueItems": true
          },
          "observation": {
            "type": "string",
            "description": "How this entry was obtained. 'missing' / 'unreachable' / 'timeout' mean the service did not report and the entry is a fail-closed placeholder.",
            "enum": [
              "observed",
              "missing",
              "unreachable",
              "timeout"
            ]
          },
          "summary": {
            "type": "string",
            "minLength": 1,
            "maxLength": 300
          },
          "last_updated_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "allOf": [
          {
            "if": {
              "properties": { "state": { "const": "degraded" } },
              "required": ["state"]
            },
            "then": {
              "required": ["degraded_subtype"]
            }
          },
          {
            "if": {
              "properties": {
                "observation": {
                  "enum": ["missing", "unreachable", "timeout"]
                }
              },
              "required": ["observation"]
            },
            "then": {
              "properties": {
                "state": { "const": "unavailable" },
                "readiness_class": { "const": "not_ready" }
              }
            }
          }
        ]
      }
    }
  }
}
